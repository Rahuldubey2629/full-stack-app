# DevPulse root env (used by docker compose)
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Azure AI Foundry / Azure AI Inference (services.ai.azure.com)
# Set LLM_PROVIDER=azure_ai
AZURE_AI_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_AI_MODEL=gpt-4o-mini
AZURE_AI_API_VERSION=2024-05-01-preview
AZURE_AI_CHAT_PATH=/models/chat/completions

# Azure OpenAI (deployment-based)
# Set LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
