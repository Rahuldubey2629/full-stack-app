{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "src/server",
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/server"],
  "exclude": ["src/client", "dist"]
}
